<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dafuweng.auth.dao.SysPermissionDao">

    <resultMap id="sysPermissionMap" type="com.dafuweng.auth.entity.SysPermissionEntity">
        <result property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="permCode" column="perm_code"/>
        <result property="permType" column="perm_type"/>
        <result property="permPath" column="perm_path"/>
        <result property="icon" column="icon"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="externalLink" column="external_link"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <!-- 根据角色ID查询权限码列表 -->
    <select id="selectPermCodesByRoleId" resultType="java.lang.String">
        SELECT p.perm_code
        FROM sys_permission p
        INNER JOIN sys_role_permission rp ON p.id = rp.permission_id
        WHERE rp.role_id = #{roleId}
    </select>

</mapper>
