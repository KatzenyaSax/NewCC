<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dafuweng.sales.dao.CustomerTransferLogDao">

    <resultMap id="customerTransferLogMap" type="com.dafuweng.sales.entity.CustomerTransferLogEntity">
        <result property="id" column="id"/>
        <result property="customerId" column="customer_id"/>
        <result property="fromRepId" column="from_rep_id"/>
        <result property="toRepId" column="to_rep_id"/>
        <result property="operateType" column="operate_type"/>
        <result property="reason" column="reason"/>
        <result property="operatedBy" column="operated_by"/>
        <result property="operatedAt" column="operated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectByCustomerId" resultMap="customerTransferLogMap">
        SELECT id, customer_id, from_rep_id, to_rep_id, operate_type,
               reason, operated_by, operated_at, deleted
        FROM customer_transfer_log
        WHERE customer_id = #{customerId} AND deleted = 0
        ORDER BY operated_at DESC
    </select>

</mapper>
