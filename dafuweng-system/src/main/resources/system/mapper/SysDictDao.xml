<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dafuweng.system.dao.SysDictDao">

    <resultMap id="sysDictMap" type="com.dafuweng.system.entity.SysDictEntity">
        <result property="id" column="id"/>
        <result property="dictType" column="dict_type"/>
        <result property="dictCode" column="dict_code"/>
        <result property="dictLabel" column="dict_label"/>
        <result property="dictValue" column="dict_value"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectByDictType" resultMap="sysDictMap">
        SELECT id, dict_type, dict_code, dict_label, dict_value,
               sort_order, status, remark, created_at, updated_at, deleted
        FROM sys_dict
        WHERE dict_type = #{dictType} AND status = 1 AND deleted = 0
        ORDER BY sort_order
    </select>

</mapper>
