<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dafuweng.finance.dao.CommissionRecordDao">

    <resultMap id="commissionRecordMap" type="com.dafuweng.finance.entity.CommissionRecordEntity">
        <result property="id" column="id"/>
        <result property="performanceId" column="performance_id"/>
        <result property="salesRepId" column="sales_rep_id"/>
        <result property="contractId" column="contract_id"/>
        <result property="commissionAmount" column="commission_amount"/>
        <result property="commissionRate" column="commission_rate"/>
        <result property="status" column="status"/>
        <result property="confirmTime" column="confirm_time"/>
        <result property="grantTime" column="grant_time"/>
        <result property="grantAccount" column="grant_account"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectBySalesRepId" resultMap="commissionRecordMap">
        SELECT id, performance_id, sales_rep_id, contract_id,
               commission_amount, commission_rate, status,
               confirm_time, grant_time, grant_account, remark,
               created_at, updated_at, deleted
        FROM commission_record
        WHERE sales_rep_id = #{salesRepId} AND deleted = 0
        ORDER BY created_at DESC
    </select>

</mapper>
